APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_USER=intel
POSTGRES_PASSWORD=intel
POSTGRES_DB=intel
DATABASE_URL=postgresql+psycopg://intel:intel@postgres:5432/intel

REDIS_URL=redis://redis:6379/0

LLM_PROVIDER=zyai
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=http://10.1.21.21:3000/v1
LLM_MODEL_CHEAP=glm-5.1
LLM_MODEL_STANDARD=glm-5.1
LLM_MODEL_STRONG=glm-5.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MAX_TOKENS=8192
LLM_MAX_TOKENS_CHEAP=4096
LLM_MAX_TOKENS_STANDARD=8192
LLM_MAX_TOKENS_STRONG=16384

WECOM_WEBHOOK_URL=
WECOM_TIMEOUT_SECONDS=10
WECOM_MAX_RETRIES=3
WECOM_MARKDOWN_MAX_BYTES=3500

COLLECTOR_MAX_RETRIES=3
COLLECTOR_RATE_LIMIT_PER_MINUTE=30
COLLECTOR_TIMEOUT_SECONDS=
ARXIV_TIMEOUT_SECONDS=
COLLECTOR_PROXY=
COLLECTOR_HTTP_PROXY=
COLLECTOR_HTTPS_PROXY=
# Example:
# COLLECTOR_PROXY=http://127.0.0.1:7897
GITHUB_TOKEN=
PUBMED_EMAIL=

WEB_SEARCH_PROVIDER=searxng
WEB_SEARCH_BASE_URL=http://localhost:8080
WEB_SEARCH_API_KEY=
WEB_DISCOVERY_MAX_RESULTS=20
WEB_DISCOVERY_ALLOWED_DOMAINS=
